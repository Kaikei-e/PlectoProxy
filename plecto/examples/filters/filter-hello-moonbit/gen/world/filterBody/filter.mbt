// filter-hello-moonbit — the filter-hello conformance subset in MoonBit, proving the
// `plecto:filter` contract is language-neutral (Component Model, zero WASI imports).
// Implements the `declare` stubs in top.mbt (generated by wit-bindgen).

///|
fn ascii_lower(s : String) -> String {
  let buf = StringBuilder::new()
  for c in s {
    if c >= 'A' && c <= 'Z' {
      buf.write_char((c.to_int() + 32).unsafe_to_char())
    } else {
      buf.write_char(c)
    }
  }
  buf.to_string()
}

///|
fn find_header(headers : Array[@types.Header], name : String) -> @types.Header? {
  for h in headers {
    if ascii_lower(h.name) == name {
      return Some(h)
    }
  }
  None
}

///|
fn text(s : String) -> FixedArray[Byte] {
  let arr = FixedArray::make(s.length(), b'\x00')
  for i in 0..<s.length() {
    arr[i] = s[i].to_byte()
  }
  arr
}

///|
pub fn init_() -> Unit {
  @hostCounter.increment("init-calls", 1L) |> ignore
}

///|
pub fn on_request(req : @types.HttpRequest) -> @types.RequestDecision {
  @hostLog.log(@hostLog.INFO, "filter-hello-moonbit: on-request")
  let inits = @hostCounter.get("init-calls")
  @hostLog.log(@hostLog.INFO, "init-calls=\{inits}")
  if find_header(req.headers, "x-plecto-addheader") is Some(_) {
    return @types.RequestDecision::Modified(@types.RequestEdit::{
      set_headers: [@types.Header::{ name: "x-plecto-added", value: "1" }],
      remove_headers: [],
    })
  }
  match find_header(req.headers, "x-plecto-ratelimit") {
    Some(rl) => {
      let key = if rl.value == "" { "default" } else { rl.value }
      let outcome = @hostRatelimit.try_acquire(key, 1UL)
      if !outcome.allowed {
        return @types.RequestDecision::ShortCircuit(@types.HttpResponse::{
          status: 429,
          headers: [
            @types.Header::{
              name: "retry-after-ms",
              value: outcome.retry_after_ms.to_string(),
            },
          ],
          body: text("rate limited by filter-hello-moonbit"),
        })
      }
    }
    None => ()
  }
  if find_header(req.headers, "x-plecto-block") is Some(_) {
    return @types.RequestDecision::ShortCircuit(@types.HttpResponse::{
      status: 403,
      headers: [@types.Header::{ name: "x-plecto", value: "blocked" }],
      body: text("blocked by filter-hello-moonbit"),
    })
  }
  @types.RequestDecision::Continue
}

///|
pub fn on_request_body(body : FixedArray[Byte]) -> @types.RequestBodyDecision {
  @hostLog.log(@hostLog.INFO, "filter-hello-moonbit: on-request-body")
  let marker = text("deny-body")
  let mlen = marker.length()
  if body.length() >= mlen {
    for i in 0..<(body.length() - mlen + 1) {
      let mut hit = true
      for j in 0..<mlen {
        let mut c = body[i + j]
        if c >= b'A' && c <= b'Z' {
          c = (c.to_int() + 32).to_byte()
        }
        if c != marker[j] {
          hit = false
          break
        }
      }
      if hit {
        return @types.RequestBodyDecision::ShortCircuit(@types.HttpResponse::{
          status: 403,
          headers: [@types.Header::{ name: "x-plecto", value: "blocked-body" }],
          body: text("blocked body by filter-hello-moonbit"),
        })
      }
    }
  }
  let upper = FixedArray::make(body.length(), b'\x00')
  for i in 0..<body.length() {
    let c = body[i]
    upper[i] = if c >= b'a' && c <= b'z' { (c.to_int() - 32).to_byte() } else { c }
  }
  @types.RequestBodyDecision::Continue(upper)
}

///|
pub fn on_response(resp : @types.HttpResponse) -> @types.ResponseDecision {
  if find_header(resp.headers, "x-plecto-respedit") is Some(_) {
    return @types.ResponseDecision::Modified(@types.ResponseEdit::{
      set_status: None,
      set_headers: [@types.Header::{ name: "x-plecto-respadded", value: "1" }],
      remove_headers: [],
    })
  }
  @types.ResponseDecision::Continue
}
