// plecto:filter@0.3.0 — response phase gains request context and replace (ADR 000073).
// `on-response` takes the as-forwarded request snapshot as its first parameter, and
// `response-decision` adds a `replace(http-response)` arm. Everything else is 0.2.0.
package plecto:filter@0.3.0;

interface types {
    record header {
        name: string,
        value: list<u8>,
    }

    record http-request {
        method: string,
        path: string,
        authority: string,
        scheme: string,
        headers: list<header>,
    }

    record http-response {
        status: u16,
        headers: list<header>,
        body: list<u8>,
    }

    record request-edit {
        set-headers: list<header>,
        remove-headers: list<string>,
    }

    record response-edit {
        set-status: option<u16>,
        set-headers: list<header>,
        remove-headers: list<string>,
    }

    variant request-decision {
        %continue,
        modified(request-edit),
        short-circuit(http-response),
    }

    variant response-decision {
        %continue,
        modified(response-edit),
        // Stop the chain and send this SYNTHESISED response instead of the upstream one
        // (upstream body stream is discarded unread — ADR 000038). Terminal: remaining
        // reverse-order filters are skipped. Host validates headers fail-closed (ADR 000071).
        replace(http-response),
    }

    variant request-body-decision {
        %continue(list<u8>),
        short-circuit(http-response),
    }
}

interface host-log {
    enum level { trace, debug, info, warn, error }
    log: func(level: level, message: string);
}

interface host-clock {
    now-ms: func() -> u64;
}

interface host-kv {
    get: func(key: string) -> option<list<u8>>;
    set: func(key: string, value: list<u8>);
    delete: func(key: string);
}

interface host-counter {
    increment: func(key: string, delta: s64) -> s64;
    get: func(key: string) -> s64;
}

interface host-ratelimit {
    record acquire {
        allowed: bool,
        remaining: u64,
        retry-after-ms: u64,
    }
    try-acquire: func(key: string, cost: u64) -> acquire;
}

interface host-config {
    get: func(key: string) -> option<string>;
}

world filter {
    use types.{http-request, http-response, request-decision, response-decision, request-body-decision};

    import host-log;
    import host-clock;
    import host-kv;
    import host-counter;
    import host-ratelimit;
    import host-config;

    export init: func();
    export on-request: func(req: http-request) -> request-decision;
    // `req` is the AS-FORWARDED request snapshot (Declared Semantics, ADR 000073): the
    // header-only request as it left the request-side chain — filter edits applied (e.g. an
    // auth filter's `x-authenticated-user` stamp), before the host's egress transforms
    // (hop-by-hop strip, upstream path rewrite, traceparent injection). Untouched inbound
    // headers such as `Origin` are still present. Value-passed: editing it does nothing.
    // `resp.body` is always empty (header-only); `replace` SYNTHESISES a body, it never reads
    // one. A `replace` decision is terminal — remaining response-chain filters are skipped.
    export on-response: func(req: http-request, resp: http-response) -> response-decision;
}

world filter-body {
    use types.{http-request, http-response, request-decision, response-decision, request-body-decision};

    import host-log;
    import host-clock;
    import host-kv;
    import host-counter;
    import host-ratelimit;
    import host-config;

    export init: func();
    export on-request: func(req: http-request) -> request-decision;
    export on-request-body: func(body: list<u8>) -> request-body-decision;
    // Same as-forwarded / replace Declared Semantics as `filter` (ADR 000073).
    export on-response: func(req: http-request, resp: http-response) -> response-decision;
}
